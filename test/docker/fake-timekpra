#!/bin/bash
# Fake timekpra stub for integration testing.
# Responds to --userinfo with parseable output.

if [[ "$1" == "--userinfo" ]]; then
    cat <<'EOF'
ALLOWED_WEEKDAYS;1;2;3;4;5;6;7
TIME_SPENT_DAY;3720
TIME_LEFT_DAY;1800
EOF
    exit 0
fi

if [[ "$1" == "--settimeleft" ]]; then
    exit 0
fi

echo "fake-timekpra: unknown args: $*" >&2
exit 1
